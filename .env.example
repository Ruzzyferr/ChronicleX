# LLM / content (Faz 2+)
OPENAI_API_KEY=
# Opsiyonel: gpt-4o-mini, gpt-4o, vb.
OPENAI_MODEL=gpt-4o-mini

# Faz 3 — DALL·E (boşsa OPENAI_API_KEY kullanılır)
DALLE_MODEL=dall-e-3
DALLE_SIZE=1024x1792

# Faz 3 — ElevenLabs TTS (veya TTS_API_KEY)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# FFmpeg / ffprobe — PATH’te yoksa .exe tam yolu (Windows: winget install -e --id Gyan.FFmpeg)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# İsteğe bağlı: ElevenLabs dışı TTS (ELEVENLABS_API_KEY ile aynı satırı iki kez yazmayın; son satır kazanır)
TTS_API_KEY=

# Images (Faz 3 — DALL·E vb.)
IMAGE_API_KEY=

# YouTube (Faz 4)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok (Faz 4 — Content Posting API; yükleme için access token gerekir)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Instagram Reels (Faz 4 — Meta Graph API: IG User ID + uzun ömürlü token)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
# İsteğe bağlı Graph sürümü (varsayılan v21.0)
FACEBOOK_GRAPH_VERSION=v21.0

# Paths & app
OUTPUT_DIR=
# Gerçek üretimde output/productions/<tarih>__<konu-slug>/ (false = eski düz output/)
OUTPUT_USE_PRODUCTION_SUBFOLDERS=true

# PostgreSQL (Faz 2+)
# Yerel Docker (docker compose up -d) ile gelen varsayılan:
# DATABASE_URL=postgresql+psycopg2://chroniclex:chroniclex@127.0.0.1:5433/chroniclex
# Kendi sunucun / prod:
# postgresql+psycopg2://kullanici:sifre@host:5432/veritabani
DATABASE_URL=

# Sadece pytest entegrasyon testleri için (boşsa Docker varsayılanı kullanılır)
# CHRONICLE_TEST_DATABASE_URL=

# İlk kurulumda tabloları otomatik oluştur (create_all). Prod’da Alembic önerilir.
AUTO_CREATE_DB_SCHEMA=true

DEFAULT_LANGUAGE=tr
DEFAULT_TIMEZONE=Europe/Istanbul

DRY_RUN=false
